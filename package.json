{
  "name": "prueba-agente-po",
  "version": "1.0.0",
  "description": "Workspace agnóstico de pruebas E2E y auditoría para cualquier plataforma",
  "scripts": {
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:ui": "playwright test --ui",
    "audit": "node scripts/audit-console-errors.js",
    "report:cycle": "node tools/scripts/generate-cycle-report-html.js",
    "deploy:pages": "node tools/scripts/deploy-pages.js",
    "lint": "eslint . --ext .js,.cjs --ignore-pattern Workspace",
    "format": "prettier --write \"**/*.{js,cjs,json,md}\""
  },
  "keywords": [
    "playwright",
    "e2e",
    "smoke-tests",
    "audit"
  ],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
